{
  "embedding": {
    "version": "v3_vllm_bge_m3",
    "provider": "http",
    "model": "bge-m3",
    "dim": 1024,
    "api_base": "http://118.196.65.175:8004/v1",
    "api_key": "",
    "timeout_s": 30,
    "endpoint": "/embeddings",
    "batch_size": 256,
    "max_workers": 8,
    "max_retries": 2,
    "retry_backoff_s": 0.5,
    "provider_max_concurrency": 8,
    "online_max_concurrency": 8,
    "online_query_max_retries": 2,
    "online_query_cache_size": 512,
    "online_query_cache_ttl_s": 300.0,
    "fail_open_on_query": false
  },
  "vector": {
    "backend": "sqlite",
    "write_mode": "sqlite_only"
  },
  "query": {
    "mode": "hybrid",
    "top_k": 10,
    "blend_strategy": "linear",
    "include_code": false,
    "max_code_chars": 1200,
    "test_code_depref_enabled": true,
    "test_code_score_factor": 0.55
  },
  "graph_query": {
    "graph_mode": "code",
    "hops": 1,
    "edge_type": "calls",
    "module_top_k": 5,
    "function_top_k": 8,
    "semantic_top_k": 8,
    "seed_fusion": "rrf",
    "module_seed_member_top_k": 3,
    "explore_default_hops_module": 2,
    "explore_default_hops_function": 1,
    "min_seed_score": 0.0
  }
}

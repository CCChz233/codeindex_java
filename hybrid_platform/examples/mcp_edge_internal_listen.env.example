# 内网监听 + 公网由 Nginx/Caddy 转发时的推荐环境变量（勿直接对公网暴露 Uvicorn）。
# 用法：在 hybrid_platform 目录下
#   set -a && source examples/mcp_edge_internal_listen.env.example && set +a
#   myenv/bin/python -m hybrid_platform.mcp_streamable_server

HYBRID_DB=/absolute/path/to/your/index.db
# HYBRID_CONFIG=/absolute/path/to/config.json

# 仅本机或内网反代可达；公网入口在边缘做 TLS
HYBRID_MCP_HOST=127.0.0.1
HYBRID_MCP_PORT=8765
HYBRID_MCP_PATH=/mcp

# 公网生产务必设置，与边缘透传的 Authorization 一致
export HYBRID_MCP_BEARER_TOKEN=your-long-random-secret

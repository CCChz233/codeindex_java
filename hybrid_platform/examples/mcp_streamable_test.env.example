# 短期联调 Streamable HTTP MCP：不启用 Bearer（勿用于公网生产）
# 用法：在 hybrid_platform 目录下
#   set -a && source examples/mcp_streamable_test.env.example && set +a
#   myenv/bin/python -m hybrid_platform.mcp_streamable_server

HYBRID_DB=/absolute/path/to/your/index.db
# HYBRID_CONFIG=/absolute/path/to/config.json

# 不设置或置空 = 不要求 Authorization Bearer
unset HYBRID_MCP_BEARER_TOKEN

HYBRID_MCP_HOST=0.0.0.0
HYBRID_MCP_PORT=8765
HYBRID_MCP_PATH=/mcp

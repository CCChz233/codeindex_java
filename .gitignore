# --- 索引与数据库（体积大）---
**/*.db
**/*.db-journal
**/*.db-wal
**/*.db-shm

# 默认索引输出目录（slug.db）
hybrid_platform/var/hybrid_indices/

# MCP 网关：nginx prefix、pid、后端日志
hybrid_platform/var/mcp_gateway/

# Java 测评准备：targets/routes/build logs/worktrees 索引辅助文件
hybrid_platform/var/java_eval/

# scip-java 等生成的 SCIP（若在仓库或 worktree 内误提交）
*.scip
**/index.scip

# 若希望 metadata 仅本机、不提交，取消下一行注释
# hybrid_platform/var/index_metadata.json

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
# pytest 在部分环境下会把 basetemp 写到工作区（例如 hybrid_platform/pytest-of-root）
hybrid_platform/pytest-of-root/
.mypy_cache/
.ruff_cache/
*.egg-info/
.eggs/
dist/
build/

# --- 虚拟环境（勿提交到 GitHub；本地重建）---
hybrid_platform/myenv/
.venv/
venv/

# --- IDE / 系统 ---
.idea/
.vscode/
*.swp
*~
.DS_Store
Thumbs.db

# --- Java / Maven / Gradle 构建输出 ---
**/target/
.gradle/

# --- 统一工作区（所有 worktree、索引、缓存、日志）---
workspace/

# --- 运行日志与进程文件 ---
*.log
*.pid

# --- 本地环境与密钥 ---
.env
.env.*

# --- 其它常见大文件 / 缓存 ---
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.lance
*.arrow
*.parquet
.huggingface/
.cache/
